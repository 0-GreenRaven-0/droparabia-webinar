---
import LB from 'country-flag-icons/string/3x2/LB';
---

<section class="relative min-h-[70vh] flex items-start overflow-hidden bg-grid">
  <img
    src="/beirut.png"
    alt=""
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 w-full h-[70%] object-cover object-top opacity-60 pointer-events-none select-none"
  />
  <div class="absolute inset-0 bg-linear-to-b from-bg-dark/30 via-transparent to-bg-dark/80 pointer-events-none"></div>
  <div class="orb-blue w-[700px] h-[700px] -top-48 -right-48 opacity-50"></div>
  <div class="orb-purple w-[600px] h-[600px] bottom-0 -left-40 opacity-35"></div>
  <div class="noise-overlay"></div>

  <div class="section relative z-10 pt-4 pb-16 w-full">
    <div class="flex flex-col items-center text-center gap-3 max-w-3xl mx-auto min-h-[65vh] sm:min-h-0">

      <h1 class="text-3xl sm:text-4xl lg:text-[3.5rem] xl:text-[4rem] font-medium leading-[1.1] text-balance gs-hero-el">
        Watch Us Build a
        <span class="gradient-text-anim">High-Earning</span>
        Online Store &amp; Copy Every Step We Take to Slowly Scale Towards
        <span class="gradient-text-anim">Your First $1–2k</span>
      </h1>

      <p class="text-sm sm:text-base text-black font-semibold gs-hero-el -mt-1 bg-bg-dark/90 px-5 py-2.5 rounded-full border-2 border-primary">
        Using Lebanon's <img src="https://purecatamphetamine.github.io/country-flag-icons/3x2/LB.svg" alt="Lebanon" class="inline w-5 h-3.5 align-middle" /> 1st dropshipping platform
      </p>

      <div class="flex items-center gap-2 bg-bg-dark/60 border-2 border-primary rounded-full px-3 py-1.5 gs-hero-el">
        <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="h-6 w-auto" />
        <span class="text-green-400 text-lg">★★★★</span>
        +500 Lebanese user
      </div>

      <div class="flex flex-wrap items-center justify-center gap-4 gs-hero-el mt-auto sm:mt-0">
        <a href="#register" class="btn-cta max-w-xs flex flex-col items-center gap-1">
          <span>Secure Your Spot Now</span>
          <span class="text-xs font-normal opacity-75 flex items-center gap-1.5">
            <span class="text-red-400">●</span>
            Only 47 spots available
          </span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power3.out', duration: 0.85 } });
  tl.from('.gs-hero-el', { y: 28, opacity: 0, stagger: 0.12 });
</script>
