---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import WhatIsDroparabia from '../components/WhatIsDroparabia.astro';
import LearnSection from '../components/LearnSection.astro';
import VSSection from '../components/VSSection.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>Droparabia Live Workshop — Build Your First Online Store in Lebanon</title>
    <meta
      name="description"
      content="Join Majd Abdulsalam in a live workshop and learn how to build a profitable dropshipping business in Lebanon using Droparabia — from scratch, step by step."
    />

    <link rel="icon" type="image/png" href="/Droparabia.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="overflow-x-hidden">

    <Hero />
    <WhatIsDroparabia />
    <LearnSection />

    <!-- CTA break 1 -->
    <div class="px-6 bg-bg-section text-center">
      <a href="#register" class="btn-cta inline-flex max-w-xs flex-col items-center gap-1">
        <span>Secure Your Spot Now</span>
        <span class="text-xs font-normal opacity-75 flex items-center gap-1.5">
          <span class="text-red-400">●</span>
          Only 47 spots available
        </span>
      </a>
    </div>

    <VSSection />
    <Testimonials />

    <!-- CTA break 2 -->
    <div class=" px-6 text-center">
      <a href="#register" class="btn-cta inline-flex max-w-xs flex-col items-center gap-1">
        <span>Secure Your Spot Now</span>
        <span class="text-xs font-normal opacity-75 flex items-center gap-1.5">
          <span class="text-red-400">●</span>
          Only 47 spots available
        </span>
      </a>
    </div>

    <FAQ />

    <!-- Final registration form -->
    <div class="py-16 px-6 bg-bg-section" id="register">
      <div class="max-w-lg mx-auto">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-center mb-3">
          You'll walk out ready to <span class="gradient-text">start building and earning</span> with ease!
        </h2>
        <p class="text-text-muted text-center text-base leading-relaxed mb-8">
          Because this is a free workshop, spots are tightly limited — be sure to secure yours to avoid missing out on a huge opportunity.
        </p>
        <RegistrationForm id="register-form" prefix="rf1" />
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-border bg-bg-dark">
      <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-2 gap-10">

        <!-- Brand -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <img src="/Droparabia.png" alt="Droparabia" class="h-10 w-auto object-contain" />
            <span style="font-family: 'IBrand', sans-serif;  font-size: 1.5rem; letter-spacing: 0.03em;">Droparabia</span>
          </div>
          <p class="text-text-muted text-sm leading-relaxed max-w-xs">
            Lebanon's first dropshipping platform — built to help you launch, sell, and scale without inventory risk.
          </p>
        </div>

        <!-- Quick links -->
        <div class="flex flex-col gap-3">
          <p class="text-xs font-bold uppercase tracking-widest text-text-muted mb-1">Quick Links</p>
          <a href="#register" class="text-sm text-text-muted hover:text-primary transition-colors no-underline">Register for the Workshop</a>
          <a href="#learn-section" class="text-sm text-text-muted hover:text-primary transition-colors no-underline">What You'll Learn</a>
          <a href="#faq" class="text-sm text-text-muted hover:text-primary transition-colors no-underline">FAQ</a>
        </div>


      </div>

      <div class="border-t border-border py-5 px-6 text-center">
        <p class="text-black text-xs">
          © {new Date().getFullYear()} Droparabia. All rights reserved. · Lebanon's #1 Dropshipping Platform
        </p>
      </div>
    </footer>

  </body>
</html>
